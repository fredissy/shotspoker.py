<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Switch Room?</title>
    <link rel="icon" type="image/svg+xml" href="{{ url_for('static', filename='img/favicon.svg') }}"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="{{ url_for('static', filename='js/theme.js') }}"></script>
</head>
<body class="d-flex align-items-center justify-content-center bg-body-tertiary" style="height: 100vh;">

    <div class="card shadow p-4 text-center" style="max-width: 450px;">
        <h3 class="mb-3">🚪 Switch Rooms?</h3>
        
        <p class="mb-4">
            You are currently in room:<br>
            <strong class="text-primary font-monospace">{{ current_room }}</strong><br><br>
            Do you want to leave it and join:<br>
            <strong class="text-success font-monospace">{{ target_room }}</strong>?
        </p>

        <div class="d-flex gap-2 justify-content-center">
            <a href="{{ url_for('room', room_id=current_room) }}" class="btn btn-secondary w-50">
                Stay Here
            </a>
            
            <a href="{{ url_for('force_switch', target_room=target_room) }}" class="btn btn-primary w-50">
                Yes, Switch
            </a>
        </div>
    </div>

</body>
</html>
